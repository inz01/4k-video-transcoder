# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Generated convenience scripts (created by setup.sh — not needed in repo)
start_api.sh
start_worker.sh

# Environment (runtime-generated .env is ignored; VM-specific templates are tracked)
.env
!.env.vm1
!.env.vm2

# Runtime directories (large video files)
uploads/
outputs/
videos/
storage/

# Logs
logs/
*.log
redis.log
worker.log
api.log

# Metrics (generated at runtime)
metrics/progress_*.json
metrics/kpi_export.csv
metrics/jobs.jsonl

# KPI report (generated charts — regenerated by kpi_compare.py)
kpi_report/*.png

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
